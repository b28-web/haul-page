#!/usr/bin/env bash
# Pre-commit hook: catches common bot mistakes before they reach CI.
# Install: git config core.hooksPath .githooks
set -euo pipefail

RED='\033[31m'
YELLOW='\033[33m'
N='\033[0m'

ERRORS=0
WARNINGS=0

warn()  { printf "${YELLOW}warning:${N} %s\n" "$1"; WARNINGS=$((WARNINGS + 1)); }
fail()  { printf "${RED}error:${N} %s\n" "$1"; ERRORS=$((ERRORS + 1)); }

# Only check staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# 1. Check for fixup/wip in commit message (via prepare-commit-msg or here)
#    Handled by CI guardrails — skip here to avoid blocking interactive rebases.

# 2. Debug statements in staged Elixir files
ELIXIR_FILES=$(echo "$STAGED" | grep '\.exs\?$' || true)
if [ -n "$ELIXIR_FILES" ]; then
  for f in $ELIXIR_FILES; do
    # Test support utilities (formatters, helpers) legitimately use IO
    case "$f" in test/support/*) continue ;; esac
    if git diff --cached "$f" | grep -q '+.*\(IO\.inspect\|IO\.puts\|dbg(\)'; then
      fail "debug statement in $f (IO.inspect/IO.puts/dbg)"
    fi
  done
fi

# 3. Debug statements in staged JS files
JS_FILES=$(echo "$STAGED" | grep '\.jsx\?\|\.tsx\?\|\.js$' || true)
if [ -n "$JS_FILES" ]; then
  for f in $JS_FILES; do
    if git diff --cached "$f" | grep -q '+.*\(console\.log\|debugger\)'; then
      warn "debug statement in $f (console.log/debugger)"
    fi
  done
fi

# 4. Hardcoded secrets (aggressive pattern)
for f in $STAGED; do
  case "$f" in
    *.ex|*.exs|*.yml|*.yaml|*.json|*.toml|*.js|*.ts)
      # Skip dev/test configs — they use standard Phoenix defaults, not real secrets
      case "$f" in config/dev.exs|config/test.exs) continue ;; esac
      if git diff --cached "$f" | grep -qiE '\+.*(password|secret_key|api_key|token)\s*[:=]\s*"[A-Za-z0-9+/]{8,}"'; then
        fail "possible hardcoded secret in $f"
      fi
      ;;
  esac
done

# 5. Large diff warning
LINES_CHANGED=$(git diff --cached --stat | tail -1 | grep -oE '[0-9]+' | head -1 || echo 0)
if [ "$LINES_CHANGED" -gt 500 ]; then
  warn "large commit: $LINES_CHANGED lines changed — consider splitting"
fi

# 6. .env files should never be committed
if echo "$STAGED" | grep -qE '\.env($|\.)'; then
  fail ".env file staged — this should be in .gitignore"
fi

# Report
if [ "$ERRORS" -gt 0 ]; then
  echo ""
  fail "commit blocked — fix $ERRORS error(s) above"
  echo "  Use --no-verify to bypass (but don't make a habit of it)"
  exit 1
fi

if [ "$WARNINGS" -gt 0 ]; then
  echo ""
  warn "$WARNINGS warning(s) — commit proceeding, but clean these up"
fi

exit 0
